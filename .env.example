# ============================================================
# Multi-Agent Competitive Intelligence System
# Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# ============================================================

# Mistral AI — get from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Serper API (Google News search) — get from https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# Firecrawl (web scraping) — get from https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Qdrant Vector DB — get from https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-id.eu-west-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# System Configuration (safe defaults — no need to change)
COLLECTION_NAME=competitor_news
EMBEDDING_MODEL=all-MiniLM-L6-v2
MISTRAL_MODEL=mistral-small-latest
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=8
REPORT_OUTPUT_DIR=reports
LOG_LEVEL=INFO
